{
  "version": 2,
  "buildCommand": "cd google-play-api && npm install",
  "outputDirectory": "google-play-api",
  "functions": {
    "google-play-api/server.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/google-play-api/server.js"
    }
  ]
}
